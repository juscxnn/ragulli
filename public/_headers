# Cloudflare Pages headers
#
# default-src 'self'
#   Strict default: only same-origin resources are loaded by default.
# script-src 'self'
#   No inline scripts, no eval. Required for the trust-panel claim.
# style-src 'self' 'unsafe-inline'
#   Same-origin stylesheets only. 'unsafe-inline' is permitted because
#   React's runtime injects a small <style> block for SVG icons; the
#   alternative is to render them all as React components (planned V1.1).
# img-src 'self' data: blob:
#   Same-origin images plus data: URLs (for tiny inline SVG data URIs in
#   the OG image) and blob: URLs (for the PDF.js rendered page bitmaps).
# font-src 'self' data:
#   All fonts are self-hosted via @fontsource/*; no Google Fonts CDN.
#   The `data:` allowance is for Tailwind v4's inline-base64 font
#   inlining of the @fontsource bundles — the bytes still originate
#   from our self-hosted package, so the trust-panel claim holds.
# connect-src 'self' https://api.openai.com https://api.anthropic.com
#   https://generativelanguage.googleapis.com https://api.minimaxi.chat
#   https://api.moonshot.cn https://ragulli-proxy.vercel.app
#   Outbound endpoints:
#     api.openai.com                  — OpenAI / GPT family (BYOK)
#     api.anthropic.com               — kept for direct calls; primary path
#                                       is the ragulli-proxy Edge function
#     generativelanguage.googleapis.com — Google / Gemini (BYOK)
#     api.minimaxi.chat                — MiniMax / M2 (BYOK)
#     api.moonshot.cn                 — Moonshot / Kimi (BYOK)
#     ragulli-proxy.vercel.app        — stateless Anthropic CORS proxy
#   Adding a new endpoint here is a trust-panel violation per spec §4.5.
# worker-src 'self' blob:
#   Same-origin Web Workers plus blob: workers (used by PDF.js and
#   Transformers.js to construct workers from in-memory bundles).
/*
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self' https://api.openai.com https://api.anthropic.com https://generativelanguage.googleapis.com https://api.minimaxi.chat https://api.moonshot.cn https://ragulli-proxy.vercel.app; worker-src 'self' blob:
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), interest-cohort=()
  Cross-Origin-Opener-Policy: same-origin
