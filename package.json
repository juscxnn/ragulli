{
  "name": "ragulli",
  "version": "0.1.0",
  "private": true,
  "description": "RAGülli — Your files. Your AI. Your browser. A browser-only private RAG application.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm run build:assets && pnpm run build:app && pnpm run build:sitemap",
    "build:assets": "node scripts/fetch-embed-model.mjs && node scripts/build-og-image.mjs && node scripts/build-samples.mjs",
    "fetch:model": "node scripts/fetch-embed-model.mjs",
    "build:app": "tsc -b && vite build",
    "build:sitemap": "node scripts/build-sitemap.mjs",
    "preview": "vite preview --port 4173",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/inter": "5.2.8",
    "@fontsource/jetbrains-mono": "5.2.8",
    "@fontsource/lora": "5.2.8",
    "@huggingface/transformers": "3.8.1",
    "@mlc-ai/web-llm": "0.2.84",
    "@mozilla/readability": "0.6.0",
    "dexie": "4.4.4",
    "mammoth": "1.12.0",
    "native-file-system-adapter": "3.0.1",
    "pdfjs-dist": "5.7.284",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "uuid": "11.1.1",
    "workbox-window": "7.4.1",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@resvg/resvg-js": "2.6.2",
    "@tailwindcss/postcss": "4.3.2",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "22.20.0",
    "@types/pdfkit": "0.17.6",
    "@types/react": "18.3.31",
    "@types/react-dom": "18.3.7",
    "@types/uuid": "11.0.0",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "9.20.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.20",
    "globals": "15.15.0",
    "jsdom": "29.1.1",
    "pdfkit": "0.19.1",
    "postcss": "8.5.16",
    "prettier": "3.9.4",
    "tailwindcss": "4.3.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0",
    "vite": "5.4.21",
    "vite-plugin-pwa": "0.21.2",
    "vitest": "2.1.9"
  }
}
